{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "server/Dockerfile",
    "watchPatterns": [
      "server/**",
      "db/**",
      "pach.config.ts",
      "drizzle.config.ts",
      "package.json",
      "pnpm-lock.yaml"
    ]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health"
  }
}
